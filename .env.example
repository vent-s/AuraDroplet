# Medusa backend on Railway
MEDUSA_BACKEND_URL=https://your-medusa-backend.up.railway.app
MEDUSA_PUBLISHABLE_KEY=pk_...

# Stripe publishable key from the same Stripe account used by Medusa
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Required server-side so Stripe can send a receipt to every checkout email.
STRIPE_SECRET_KEY=sk_...

# Completed-order notifications use Resend. ORDER_EMAIL_FROM must be a verified
# sender/domain in Resend. The notification recipient defaults to talaliggy15@gmail.com.
RESEND_API_KEY=re_...
ORDER_EMAIL_FROM=orders@your-verified-domain.com
ORDER_NOTIFICATION_EMAIL=talaliggy15@gmail.com
# Generate a long random value. Required to call POST /api/order-email-test.
ORDER_EMAIL_TEST_SECRET=

# PostHog web analytics and funnel tracking
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_SESSION_REPLAY=false

# Shared with VelluraCare. Generate a long random value and keep it server-only.
CHECKOUT_HANDOFF_SECRET=

# Production handoff token storage. Local development falls back to memory.
KV_REST_API_URL=
KV_REST_API_TOKEN=
# or
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: pin checkout to explicit variant IDs instead of resolving by handle.
# If omitted, Satielle resolves `satielle-diffuser-kit` from Medusa.
SATIELLE_MEDUSA_VARIANT_ID=

# VelluraCare product variant pins. If omitted, Satielle resolves by product handle.
RETATRUTIDE_MEDUSA_VARIANT_ID=
SEMAGLUTIDE_MEDUSA_VARIANT_ID=
TIRZEPATIDE_MEDUSA_VARIANT_ID=

# Legacy semaglutide fallback. Prefer SEMAGLUTIDE_MEDUSA_VARIANT_ID going forward.
VELLURACARE_MEDUSA_VARIANT_ID=
CHECKOUT_HANDOFF_TTL_SECONDS=900
